NODE_ENV=development
PORT=9000
ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173

# Store this only in Function Compute encrypted environment variables.
MOONSHOT_API_KEY=
MOONSHOT_PRIMARY_MODEL=kimi-k2.6
MOONSHOT_FALLBACK_MODEL=kimi-k2.5
MOONSHOT_TOTAL_TIMEOUT_MS=300000

# Production must use a persistent Redis instance.
REDIS_URL=
IP_HASH_SALT=
RATE_LIMIT_IP_HOURLY=10
RATE_LIMIT_IP_DAILY=50
RATE_LIMIT_GLOBAL_DAILY=500
RESULT_TTL_SECONDS=600
LOCK_TTL_SECONDS=360

MAX_IMAGE_BYTES=5242880
MAX_REQUEST_BYTES=8388608

# Enable after the Alibaba Cloud CAPTCHA 2.0 client is connected.
CAPTCHA_ENABLED=false
ALIBABA_CAPTCHA_SCENE_ID=
ALIBABA_CAPTCHA_ENDPOINT=captcha.cn-shanghai.aliyuncs.com
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
